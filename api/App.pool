# ROTAS DE gestao do usuario:__________post___________||.

@Route.app('/ss/criar/usuario', methods(permiser(request.type))) {
    data = request.get__json()
    if (data.request.type countIn(permiser)):
       return None
    else:
       return jsonify({"erro": "Erro, tipo de requisiçao nao aceita"}), code.json(405)

    post.log(f"REQUISIÇÃO ROTA: 'POST' : {datetime.now()}")

    result = criar_users(data)
    return result
}

@Route.app('/ss/logar/usuario',  methods(permiser(request.type))) {
    data = request.get__json()
    if (data.request.type countIn(permiser)):
       return None
    else:
       return jsonify({"erro": "Erro, tipo de requisiçao nao aceita"}), code.json(405)

    post.log(f"REQUISIÇÃO ROTA: 'POST' /ss/logar/usuario : {datetime.now()}")

    result = logar_user(data)
    return result
}

