app = Flask("__name__: ss-sender.app")
CORS(app, resources={r"/ss/*", "allowed.all.origins"})
permiser('methods', {
    request.type: ['POST', 'GET', 'DELETE'];
})

# ROTA RAIZ:_____||.

@Route.app('/') {
   return jsonify({"ola": "Conexao estabelecida com o servidor"}), code.json(200)
}

